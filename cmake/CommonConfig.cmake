# =================== 编译选项 ===================
set(CMAKE_CXX_STANDARD 20)
set(CMAKE_CXX_STANDARD_REQUIRED ON)

set(CMAKE_C_FLAGS "${CMAKE_C_FLAGS} -pthread")
set(CMAKE_CXX_FLAGS "${CMAKE_CXX_FLAGS} -pthread")

OPTION(ENABLE_COVERAGE "Use gcov" OFF)
OPTION(ENABLE_SANITIZE_THREAD "Use sanitize thread" OFF)
OPTION(ENABLE_SANITIZE_ADDRESS "Use sanitize address" OFF)

if(NOT CMAKE_BUILD_TYPE)
    set(CMAKE_BUILD_TYPE Release)
endif()
message(STATUS "Build type: ${CMAKE_BUILD_TYPE}")
IF(CMAKE_BUILD_TYPE STREQUAL "Release")
    MESSAGE(STATUS "Release build")
    SET(CMAKE_CXX_FLAGS "${CMAKE_CXX_FLAGS} -O3")
    SET(CMAKE_C_FLAGS "${CMAKE_C_FLAGS} -O3")
ELSE()
    MESSAGE(STATUS "Debug build")
    SET(CMAKE_CXX_FLAGS "${CMAKE_CXX_FLAGS} -O0 -g")
    SET(CMAKE_C_FLAGS "${CMAKE_C_FLAGS} -O0 -g")
ENDIF()

MESSAGE(STATUS ENABLE_COVERAGE=${ENABLE_COVERAGE})
IF(ENABLE_COVERAGE)
    MESSAGE(STATUS ENABLE_COVERAGE)
    SET(CMAKE_CXX_FLAGS "${CMAKE_CXX_FLAGS} -fprofile-arcs -ftest-coverage")
    SET(CMAKE_C_FLAGS "${CMAKE_C_FLAGS} -fprofile-arcs -ftest-coverage")
ENDIF()

MESSAGE(STATUS ENABLE_SANITIZE_THREAD=${ENABLE_SANITIZE_THREAD})
IF(ENABLE_SANITIZE_THREAD)
    MESSAGE(STATUS ENABLE_SANITIZE_THREAD)
    SET(CMAKE_CXX_FLAGS "${CMAKE_CXX_FLAGS} -fsanitize=thread -fno-omit-frame-pointer")
    SET(CMAKE_C_FLAGS "${CMAKE_C_FLAGS} -fsanitize=thread -fno-omit-frame-pointer")
ENDIF()

MESSAGE(STATUS ENABLE_SANITIZE_ADDRESS=${ENABLE_SANITIZE_ADDRESS})
IF(ENABLE_SANITIZE_ADDRESS)
    MESSAGE(STATUS ENABLE_SANITIZE_ADDRESS)
    SET(CMAKE_CXX_FLAGS "${CMAKE_CXX_FLAGS} -fsanitize=address -fno-omit-frame-pointer")
    SET(CMAKE_C_FLAGS "${CMAKE_C_FLAGS} -fsanitize=address -fno-omit-frame-pointer")
ENDIF()