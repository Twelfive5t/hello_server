# 版本
SERVER_VERSION=1.0.0
# ----------------------------------------------------------------------
# 镜像前缀
IMAGE_PRIFIX=docker.io/twelfive5t
# 构建镜像
BUILDER_IMAGE=${IMAGE_PRIFIX}/server_builder
# 制品镜像
PRODUCT_IMAGE=${IMAGE_PRIFIX}/server_product:${SERVER_VERSION}
